{
  "$schema": "https://fastedge-plugin-source/manifest/v1",
  "repo_id": "fastedge-test",
  "version": "1.0.0",
  "sources": {
    "testing-api": {
      "files": [
        "docs/TEST_FRAMEWORK.md",
        "docs/API.md",
        "docs/WEBSOCKET.md",
        "docs/RUNNER.md"
      ],
      "required": true,
      "description": "Test framework API, REST endpoints, WebSocket protocol, and low-level runner interface"
    },
    "test-config": {
      "files": [
        "docs/TEST_CONFIG.md",
        "schemas/fastedge-config.test.schema.json"
      ],
      "required": true,
      "description": "Test configuration schema, dotenv setup, and usage examples"
    },
    "vscode-debugger": {
      "files": [
        "docs/DEBUGGER.md"
      ],
      "required": false,
      "description": "Debugger server CLI usage, programmatic startup, port configuration, and environment variables"
    }
  },
  "target_mapping": {
    "testing-api": {
      "reference_file": "plugins/gcore-fastedge/skills/test/reference/testing-api.md",
      "section": null
    },
    "test-config": {
      "reference_file": "plugins/gcore-fastedge/skills/test/reference/test-config.md",
      "section": null
    },
    "vscode-debugger": {
      "reference_file": "plugins/gcore-fastedge/skills/test/reference/vscode-debugger.md",
      "section": null
    }
  },
  "validation": {
    "mode": "advisory",
    "strict_fields": ["testing-api"]
  }
}
