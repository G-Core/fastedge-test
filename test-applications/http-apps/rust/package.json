{
  "name": "http_rust_apps",
  "version": "0.0.1",
  "description": "FastEdge HTTP applications for integration tests - Rust basic and wasi variants",
  "scripts": {
    "build": "npm-run-all -s build:basic copy:basic build:wasi copy:wasi",
    "build:basic": "cd basic && cargo build --release",
    "build:wasi": "cd wasi && cargo build --release",
    "copy:basic": "npm-run-all -p copy:basic:hello-world copy:basic:http-responder copy:basic:downstream-fetch copy:basic:headers copy:basic:variables-and-secrets",
    "copy:basic:hello-world": "cp basic/target/wasm32-wasip1/release/hello_world.wasm ../../../wasm/http-apps/rust/basic/hello-world.wasm",
    "copy:basic:http-responder": "cp basic/target/wasm32-wasip1/release/http_responder.wasm ../../../wasm/http-apps/rust/basic/http-responder.wasm",
    "copy:basic:downstream-fetch": "cp basic/target/wasm32-wasip1/release/downstream_fetch.wasm ../../../wasm/http-apps/rust/basic/downstream-fetch.wasm",
    "copy:basic:headers": "cp basic/target/wasm32-wasip1/release/headers.wasm ../../../wasm/http-apps/rust/basic/headers.wasm",
    "copy:basic:variables-and-secrets": "cp basic/target/wasm32-wasip1/release/variables_and_secrets.wasm ../../../wasm/http-apps/rust/basic/variables-and-secrets.wasm",
    "copy:wasi": "npm-run-all -p copy:wasi:hello-world copy:wasi:http-responder copy:wasi:downstream-fetch copy:wasi:headers copy:wasi:variables-and-secrets",
    "copy:wasi:hello-world": "cp wasi/target/wasm32-wasip1/release/hello_world.wasm ../../../wasm/http-apps/rust/wasi/hello-world.wasm",
    "copy:wasi:http-responder": "cp wasi/target/wasm32-wasip1/release/http_responder.wasm ../../../wasm/http-apps/rust/wasi/http-responder.wasm",
    "copy:wasi:downstream-fetch": "cp wasi/target/wasm32-wasip1/release/downstream_fetch.wasm ../../../wasm/http-apps/rust/wasi/downstream-fetch.wasm",
    "copy:wasi:headers": "cp wasi/target/wasm32-wasip1/release/headers.wasm ../../../wasm/http-apps/rust/wasi/headers.wasm",
    "copy:wasi:variables-and-secrets": "cp wasi/target/wasm32-wasip1/release/variables_and_secrets.wasm ../../../wasm/http-apps/rust/wasi/variables-and-secrets.wasm"
  },
  "license": "ISC"
}
