{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/HookCall",
  "definitions": {
    "HookCall": {
      "type": "object",
      "properties": {
        "hook": {
          "type": "string"
        },
        "request": {
          "type": "object",
          "properties": {
            "headers": {
              "$ref": "#/definitions/HeaderRecord"
            },
            "body": {
              "type": "string"
            },
            "method": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "scheme": {
              "type": "string"
            }
          },
          "required": [
            "headers",
            "body"
          ]
        },
        "response": {
          "type": "object",
          "properties": {
            "headers": {
              "$ref": "#/definitions/HeaderRecord"
            },
            "body": {
              "type": "string"
            },
            "status": {
              "type": "number"
            },
            "statusText": {
              "type": "string"
            }
          },
          "required": [
            "headers",
            "body"
          ],
          "description": "Seed state for the response hooks (`onResponseHeaders` / `onResponseBody`) when calling them in isolation via `callHook()`. The full-flow path (`callFullFlow`) generates the upstream response at runtime and does not consume this field — request hooks ignore it, and response hooks are called with the response built from the live origin fetch or built-in responder output."
        },
        "properties": {
          "type": "object",
          "additionalProperties": {}
        },
        "dotenvEnabled": {
          "type": "boolean"
        },
        "enforceProductionPropertyRules": {
          "type": "boolean"
        }
      },
      "required": [
        "hook",
        "request",
        "properties"
      ]
    },
    "HeaderRecord": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      }
    }
  }
}
