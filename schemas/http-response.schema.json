        "sec-websocket-version": {
          "type": "string"
        },
        "set-cookie": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "strict-transport-security": {
          "type": "string"
        },
        "tk": {
          "type": "string"
        },
        "trailer": {
          "type": "string"
        },
        "transfer-encoding": {
          "type": "string"
        },
        "upgrade": {
