        },
        "pragma": {
          "type": "string"
        },
        "proxy-authenticate": {
          "type": "string"
        },
        "proxy-authorization": {
          "type": "string"
        },
        "public-key-pins": {
          "type": "string"
        },
        "range": {
          "type": "string"
        },
        "referer": {
          "type": "string"
        },
        "retry-after": {
          "type": "string"
